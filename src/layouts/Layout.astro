---
import '@fontsource/ephesis';
import '@fontsource/lora/400.css';
import '@fontsource/lora/400-italic.css';
import '@fontsource/lora/600.css';
import '@fontsource/lora/600-italic.css';
import '@fontsource/lora/700.css';
import '@fontsource/lora/700-italic.css';
import '@fontsource/dm-sans/300.css';
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import '@fontsource/dm-sans/600.css';
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Genevieve Ovsak',
  description = 'Product Owner & Lead Product Designer at Optum NPD — building Violet, a sensor-driven AI-assisted caregiver platform. Background in product strategy, healthcare UX, and engineering.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={`${Astro.site}og-image.png`} />
    <meta property="og:site_name" content="Genevieve Ovsak" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${Astro.site}og-image.png`} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Genevieve Ovsak",
      "url": Astro.site?.href,
      "jobTitle": "Product Owner & Lead Product Designer",
      "worksFor": { "@type": "Organization", "name": "UnitedHealth Group / Optum" },
      "alumniOf": { "@type": "EducationalOrganization", "name": "Furman University" },
      "email": "mailto:genevieve.ovsak@gmail.com",
      "sameAs": [
        "https://linkedin.com/in/genevieve-ovsak-aa8998224",
        "https://github.com/genevieveovsak"
      ]
    })} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ── Variables ─────────────────────────────── */
  :root {
    --bg: #1a0f14;
    --surface: #251520;
    --surface-2: #2f1c28;
    --border: #4a2a3a;
    --text: #f7f0f3;
    --muted: #cfa8b8;       /* WCAG AAA on --bg: ~7.2:1 */
    --muted-2: #8a5c6e;
    --accent: #d45f82;       /* raspberry — brighter for dark bg */
    --accent-2: #9b3d61;     /* mulberry */
    --accent-3: #6e2445;     /* merlot deep */
    --accent-alt: #a0bc8a;   /* sage green */
    --text-secondary: #dfc8d2; /* secondary text — between --muted and --text */
    --gradient: linear-gradient(135deg, #d45f82 0%, #9b3d61 60%, #6e2445 100%);
    --gradient-warm: linear-gradient(135deg, #d45f82 0%, #c47a96 100%);
    --gradient-jewel: linear-gradient(135deg, #9b3d61 0%, #d45f82 100%);
    --font-display: 'Lora', Georgia, serif;
    --font-hero: 'Ephesis', cursive;
    --font-body: 'DM Sans', system-ui, -apple-system, sans-serif;
    --max-w: 1100px;
    --nav-h: 68px;
    --radius: 12px;
  }

  /* ── Reset ──────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  a { color: inherit; text-decoration: none; }
  ul { list-style: none; }
  img { max-width: 100%; display: block; }

  /* ── Container ──────────────────────────────── */
  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Nav ────────────────────────────────────── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: var(--nav-h);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    background: rgba(26, 15, 20, 0.85);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 2rem;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
  }
  .nav-logo-mark {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: var(--gradient-jewel);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    font-style: normal;
    color: white;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }
  .nav-logo-name {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-style: italic;
    color: var(--text);
    line-height: 1;
    letter-spacing: 0.01em;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }
  .nav-links a {
    font-size: 0.875rem;
    color: var(--text-secondary);
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--accent); }
  .nav-cta {
    font-size: 0.8rem !important;
    font-weight: 600 !important;
    padding: 0.45rem 1.1rem;
    border-radius: 8px;
    background: var(--gradient-jewel) !important;
    -webkit-text-fill-color: white !important;
    color: white !important;
    transition: opacity 0.2s !important;
  }
  .nav-cta:hover { opacity: 0.85 !important; }
  .nav-mobile-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 4px;
  }
  .nav-mobile-btn span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: all 0.3s;
  }

  /* ── Sections ───────────────────────────────── */
  .section { padding: 6rem 0; scroll-margin-top: var(--nav-h); }
  .section-alt { background: var(--surface); border-top: 1px solid rgba(160, 188, 138, 0.08); border-bottom: 1px solid rgba(160, 188, 138, 0.08); }
  .section-header { margin-bottom: 3rem; }
  .section-label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-alt);
    margin-bottom: 0.75rem;
    padding-bottom: 0.35rem;
    border-bottom: 1.5px solid transparent;
    border-image: linear-gradient(90deg, var(--accent-alt), var(--accent)) 1;
  }
  .section-header h2 {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 3.4rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--text);
    margin-bottom: 1rem;
    font-style: normal;
    background: linear-gradient(135deg, var(--text) 0%, var(--text-secondary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .section-desc {
    color: var(--text-secondary);
    max-width: 580px;
    font-size: 1.05rem;
  }

  /* ── Buttons ────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.8rem 1.8rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.2s;
    cursor: pointer;
    letter-spacing: 0.01em;
    border: none;
    font-family: var(--font-body);
  }
  .btn-primary {
    background: var(--gradient);
    color: white;
    padding: 0.95rem 2.25rem;
    font-size: 0.95rem;
  }
  .btn-primary:hover {
    opacity: 0.88;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(212, 95, 130, 0.38);
  }
  .btn-secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
    padding: 0.72rem 1.5rem;
    font-size: 0.85rem;
  }
  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }
  /* ── Hero orb animations ────────────────────── */
  .hero-orbs {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    opacity: 0;
  }
  @media (prefers-reduced-motion: no-preference) {
    .orb { opacity: 1; }
    .orb-1 {
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(155, 61, 97, 0.6) 0%, rgba(155, 61, 97, 0.15) 50%, transparent 75%);
      filter: blur(50px);
      top: -160px;
      left: -140px;
      animation: orb-drift-1 12s ease-in-out infinite;
    }
    .orb-2 {
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(212, 95, 130, 0.55) 0%, rgba(212, 95, 130, 0.12) 50%, transparent 75%);
      filter: blur(45px);
      top: 20%;
      right: -100px;
      animation: orb-drift-2 15s ease-in-out infinite;
    }
    .orb-3 {
      width: 420px;
      height: 420px;
      background: radial-gradient(circle, rgba(110, 36, 69, 0.55) 0%, rgba(110, 36, 69, 0.12) 50%, transparent 75%);
      filter: blur(40px);
      bottom: 10%;
      left: 30%;
      animation: orb-drift-3 18s ease-in-out infinite;
    }
  }
  @keyframes orb-drift-1 {
    0%,  100% { transform: translate(0px,    0px)   scale(1);    }
    25%        { transform: translate(90px,  -70px)  scale(1.12); }
    60%        { transform: translate(-60px,  90px)  scale(0.92); }
    80%        { transform: translate(50px,   50px)  scale(1.07); }
  }
  @keyframes orb-drift-2 {
    0%,  100% { transform: translate(0px,    0px)   scale(1);    }
    30%        { transform: translate(-90px,  70px)  scale(1.14); }
    65%        { transform: translate(70px,  -60px)  scale(0.9);  }
  }
  @keyframes orb-drift-3 {
    0%,  100% { transform: translate(0px,    0px)   scale(1);    }
    35%        { transform: translate(80px,  -90px)  scale(1.1);  }
    70%        { transform: translate(-70px,  60px)  scale(0.93); }
  }

  /* ── Hero ───────────────────────────────────── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    padding-top: var(--nav-h);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 10% 50%, rgba(155, 61, 97, 0.22) 0%, transparent 65%),
      radial-gradient(ellipse 50% 40% at 85% 55%, rgba(110, 36, 69, 0.15) 0%, transparent 60%),
      radial-gradient(ellipse 40% 30% at 50% 80%, rgba(212, 95, 130, 0.09) 0%, transparent 55%);
    pointer-events: none;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(74, 42, 58, 0.7) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }
  .hero .container {
    position: relative;
    z-index: 1;
    padding-top: 2rem;
    padding-bottom: 4rem;
  }
  .hero-name {
    font-family: var(--font-hero);
    font-size: clamp(3.5rem, 12vw, 9rem);
    font-weight: 400;
    font-style: normal;
    letter-spacing: -0.01em;
    line-height: 1.25;
    margin-bottom: 0.75rem;
    color: var(--text);
    overflow: visible;
    white-space: nowrap;
  }
  .hero-name .gradient-text {
    color: var(--accent);
    font-weight: 400;
  }
  .hero-callout {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    margin-top: 0;
    margin-bottom: 2rem;
  }
  .hero-callout-rule {
    flex: 1;
    max-width: 60px;
    height: 1px;
    background: var(--accent-alt);
    opacity: 0.5;
  }
  .hero-callout-text {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 700;
    font-style: normal;
    color: var(--accent-alt);
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .hero-script {
    display: none;
  }
  .hero-tagline {
    font-size: clamp(1rem, 2.5vw, 1.175rem);
    color: var(--text-secondary);
    max-width: 540px;
    line-height: 1.75;
    margin-bottom: 2.5rem;
    margin-top: 0;
  }
  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3.5rem;
  }
  .hero-location {
    font-size: 0.82rem;
    color: var(--accent-alt);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .hero-location-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--accent-alt);
  }

  /* ── Focus Grid ─────────────────────────────── */
  .focus-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
  }
  .focus-card {
    flex: 0 0 calc((100% - 3rem) / 3);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
  }
  .focus-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent) 0%, var(--accent-alt) 100%);
    opacity: 0;
    transition: opacity 0.25s;
  }
  .focus-card:hover {
    border-color: rgba(160, 188, 138, 0.35);
    background: var(--surface-2);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4), 0 0 30px rgba(160, 188, 138, 0.07);
  }
  .focus-card:hover::after { opacity: 1; }
  .focus-num {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 1.1rem;
  }
  .focus-card h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    font-style: normal;
    letter-spacing: 0.01em;
    margin-bottom: 0.75rem;
    color: var(--text);
  }
  .focus-card p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ── Timeline ───────────────────────────────── */
  .timeline {
    position: relative;
    padding-left: 2.5rem;
  }
  .timeline::before {
    content: '';
    position: absolute;
    top: 10px; bottom: 0; left: 4px;
    width: 1px;
    background: linear-gradient(to bottom, var(--accent-alt), var(--accent), rgba(110, 36, 69, 0));
    opacity: 0.55;
  }
  .timeline-item {
    position: relative;
    padding-bottom: 2.5rem;
  }
  .timeline-item:last-child { padding-bottom: 0; }
  .timeline-dot {
    position: absolute;
    left: -2.8rem;
    top: 8px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent-alt), var(--accent));
    box-shadow: 0 0 14px rgba(160, 188, 138, 0.5);
  }
  .timeline-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .timeline-card:hover {
    border-color: rgba(160, 188, 138, 0.42);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }
  /* Current role — accent left border */
  .timeline-item:first-child .timeline-card {
    border-left: 3px solid var(--accent);
    background: linear-gradient(135deg, rgba(212, 95, 130, 0.04) 0%, var(--surface-2) 60%);
  }
  .timeline-item:first-child .timeline-dot {
    width: 13px;
    height: 13px;
    left: -2.9rem;
    box-shadow: 0 0 20px rgba(212, 95, 130, 0.65);
  }
  /* De-emphasize older roles visually */
  .timeline-item:nth-child(n+4) .timeline-card {
    padding: 1.25rem 1.5rem;
    border-color: rgba(74, 42, 58, 0.55);
  }
  .timeline-item:nth-child(n+4) .timeline-dot {
    width: 8px;
    height: 8px;
    opacity: 0.65;
    box-shadow: 0 0 8px rgba(160, 188, 138, 0.2);
  }
  .timeline-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .timeline-period {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--accent);
  }
  .timeline-location { font-size: 0.78rem; color: var(--text-secondary); }
  .timeline-role {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    font-style: normal;
    letter-spacing: 0.01em;
    color: var(--text);
    margin-bottom: 0.2rem;
  }
  .timeline-company {
    font-size: 0.875rem;
    margin-bottom: 1rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    background: linear-gradient(90deg, var(--accent-alt), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .timeline-bullets { margin-bottom: 1.25rem; }
  .timeline-bullets li {
    font-size: 0.875rem;
    color: var(--text-secondary);
    padding-left: 1.2rem;
    position: relative;
    margin-bottom: 0.5rem;
    line-height: 1.65;
  }
  .timeline-bullets li::before {
    content: '↗';
    position: absolute;
    left: 0;
    color: var(--accent-alt);
    font-size: 0.7rem;
    top: 0.2rem;
  }
  .tags { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .tag {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    background: rgba(212, 95, 130, 0.22);
    color: var(--text);
    border: 1px solid rgba(212, 95, 130, 0.45);
  }

  /* ── Education ──────────────────────────────── */
  .edu-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2.5rem;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2.5rem;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
  }
  .edu-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 3px;
    background: linear-gradient(to bottom, var(--accent-alt), var(--accent));
    border-radius: 4px 0 0 4px;
  }
  .edu-school {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    font-style: normal;
    letter-spacing: 0.01em;
    color: var(--text);
    margin-bottom: 0.4rem;
  }
  .edu-location { font-size: 0.82rem; color: var(--text-secondary); line-height: 1.6; }
  .edu-degree {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    font-style: normal;
    letter-spacing: 0.01em;
    color: var(--text);
    margin-bottom: 0.2rem;
  }
  .edu-minor { font-size: 0.875rem; color: var(--text-secondary); margin-bottom: 1.1rem; }
  .edu-honors { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
  .honor-badge {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.28rem 0.75rem;
    border-radius: 999px;
    background: rgba(160, 188, 138, 0.1);
    color: var(--accent-alt);
    border: 1px solid rgba(160, 188, 138, 0.28);
  }
  .edu-note { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.65; }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .project-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: all 0.25s;
  }
  .project-card:hover {
    border-color: rgba(160, 188, 138, 0.35);
    transform: translateY(-2px);
  }
  .project-year {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-alt);
    margin-bottom: 0.6rem;
  }
  .project-card h4 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    font-style: normal;
    letter-spacing: 0.01em;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .project-card p { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.6; }

  /* ── Skills ─────────────────────────────────── */
  .skills-grid {
