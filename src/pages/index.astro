  </section>

  <!-- ── CLIENT WORK ─────────────────────────────── -->
  <section id="work" class="section section-alt">
    <div class="container">
      <div class="section-header fade-up">
        <span class="section-label">Shipped & Live</span>
        <h2>Client Work</h2>
